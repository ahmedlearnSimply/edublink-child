{#
 * Header Component
 * 
 * Main site header with logo, navigation, and auth buttons
 #}

<!-- ===== START: Header Section ===== -->
<header class="learnsimply-header-main-container">
  <div class="learnsimply-header-border-overlay"></div>

  <div class="learnsimply-header-content-wrapper">
    <!-- Right Side: Logo and Menu -->
    <div class="learnsimply-header-right-side">
      <!-- Logo -->
      <a href="{{ site.url }}" class="learnsimply-header-logo-container">
        <div class="learnsimply-header-logo-image-wrapper">
          <img
            src="{{ theme_uri }}/assets/img/logo.png"
            alt="اتعلم ببساطة"
            class="learnsimply-header-logo-image"
          />
        </div>
        <p class="learnsimply-header-logo-text">اتعلم ببساطة</p>
      </a>

      <!-- Navigation Menu -->
      <nav class="learnsimply-header-navigation-menu">
        {% if main_menu and main_menu.items %}
          {% for item in main_menu.items %}
            <a 
              href="{{ item.url }}" 
              class="learnsimply-header-menu-item {% if item.current %}learnsimply-header-menu-item-active{% endif %}"
              {% if item.target %}target="{{ item.target }}"{% endif %}
            >
              <p class="learnsimply-header-menu-text {% if item.current %}learnsimply-header-menu-text-active{% endif %}">
                {{ item.title }}
              </p>
            </a>
          {% endfor %}
        {% else %}
          {# Fallback menu if main_menu is not available #}
        <a href="{{ site.url }}" class="learnsimply-header-menu-item {% if is_front_page %}learnsimply-header-menu-item-active{% endif %}">
          <p class="learnsimply-header-menu-text {% if is_front_page %}learnsimply-header-menu-text-active{% endif %}">
            الرئيسية
          </p>
        </a>
        {% endif %}
      </nav>
    </div>

    <!-- Left Side: Cart + Auth Buttons -->
    <div class="learnsimply-header-auth-buttons-container">
      <!-- Cart Button -->
      <a href="{{ cart_url ?: site.url ~ '/cart-1/' }}" class="learnsimply-header-cart-button" aria-label="السلة">
        <img class="learnsimply-header-cart-icon" src="{{ theme_uri }}/assets/img/Cart.png" alt="سلة التسوق" />
        {% if cart_count and cart_count > 0 %}
          <span class="learnsimply-header-cart-count">{{ cart_count }}</span>
        {% endif %}
      </a>

      {% if user %}
        <a href="{{ site.url }}/dashboard/" class="learnsimply-header-btn-login">
          <span class="learnsimply-header-btn-text">حسابي</span>
        </a>
      {% else %}
        <a href="{{ site.url }}/dashboard/" class="learnsimply-header-btn-login">
          <span class="learnsimply-header-btn-text">تسجيل دخول</span>
        </a>
        <a href="{{ site.url }}/signup/" class="learnsimply-header-btn-signup">
          <span class="learnsimply-header-btn-text">انشاء حساب</span>
        </a>
      {% endif %}
    </div>

    <!-- Mobile Menu Toggle -->
    <button class="learnsimply-header-mobile-toggle" aria-label="القائمة">
      <span class="learnsimply-mobile-toggle-bar"></span>
      <span class="learnsimply-mobile-toggle-bar"></span>
      <span class="learnsimply-mobile-toggle-bar"></span>
    </button>
  </div>
</header>
<!-- ===== END: Header Section ===== -->

{% if promo_banner_enabled %}
<!-- ===== START: Promo Banner Section ===== -->
<section class="learnsimply-promo-banner">
  <div class="learnsimply-promo-banner-inner">
    <div class="learnsimply-promo-content">

      <!-- Right Side: Text Section -->
      <div class="learnsimply-promo-text-section">
        <!-- Line 1 -->
        <div class="learnsimply-promo-text-line">
          <span class="learnsimply-promo-emoji learnsimply-promo-emoji-lg">{{ promo_emoji|default('🔥') }}</span>
          <p class="learnsimply-promo-text-primary">
            {% if promo_highlight %}
              {{ promo_text_primary|default('خصم 50% لمدة 3 أيام فقط — العرض سينتهي قريبًا!')|replace({(promo_highlight): '<span class="learnsimply-promo-highlight">' ~ promo_highlight ~ '</span>'})|raw }}
            {% else %}
              {{ promo_text_primary|default('خصم 50% لمدة 3 أيام فقط — العرض سينتهي قريبًا!') }}
            {% endif %}
          </p>
        </div>
        <!-- Line 2 -->
        <div class="learnsimply-promo-text-line">
          <span class="learnsimply-promo-emoji learnsimply-promo-emoji-sm">{{ promo_emoji|default('🔥') }}</span>
          <p class="learnsimply-promo-text-secondary">
            {{ promo_text_secondary|default('الأماكن محدودة — الحق العرض قبل انتهاء المدة!') }}
          </p>
        </div>
      </div>

      <!-- Center: Countdown Timer -->
      <div class="learnsimply-promo-countdown">
        <div class="learnsimply-promo-timer-unit">
          <div class="learnsimply-promo-timer-box">
            <span class="learnsimply-promo-timer-number" id="promo-seconds">00</span>
          </div>
          <span class="learnsimply-promo-timer-label">ثانية</span>
        </div>
        <span class="learnsimply-promo-timer-separator">:</span>
        <div class="learnsimply-promo-timer-unit">
          <div class="learnsimply-promo-timer-box">
            <span class="learnsimply-promo-timer-number" id="promo-minutes">00</span>
          </div>
          <span class="learnsimply-promo-timer-label">دقيقة</span>
        </div>
        <span class="learnsimply-promo-timer-separator">:</span>
        <div class="learnsimply-promo-timer-unit">
          <div class="learnsimply-promo-timer-box">
            <span class="learnsimply-promo-timer-number" id="promo-hours">00</span>
          </div>
          <span class="learnsimply-promo-timer-label">ساعة</span>
        </div>
        <span class="learnsimply-promo-timer-separator">:</span>
        <div class="learnsimply-promo-timer-unit">
          <div class="learnsimply-promo-timer-box">
            <span class="learnsimply-promo-timer-number" id="promo-days">00</span>
          </div>
          <span class="learnsimply-promo-timer-label">يوم</span>
        </div>
      </div>

      <!-- Left Side: CTA Button -->
      <a href="{{ promo_cta_url|default(site.url)|e('html_attr') }}" class="learnsimply-promo-cta-btn">
        <span class="learnsimply-promo-cta-text">{{ promo_cta_text|default('اشترك الآن') }}</span>
      </a>

    </div>
  </div>
</section>
<!-- ===== END: Promo Banner Section ===== -->
{% endif %}
