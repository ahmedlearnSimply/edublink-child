{% extends "layouts/base.twig" %}

{% block body_class %}learnsimply-homepage-body lc-cart-page{% endblock %}

{% block content %}

<div class="lc-cart">

    {% if has_items %}

    {# ── Page Hero ──────────────────────────────────────────── #}
    <div class="lc-cart-hero">
        <div class="lc-cart-hero__icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
            </svg>
        </div>
        <div class="lc-cart-hero__text">
            <h1 class="lc-cart-hero__title">سلة التسوق</h1>
            <p class="lc-cart-hero__count">
                {% if total_count == 1 %}
                    دورة واحدة في سلتك
                {% else %}
                    {{ total_count }} دورات في سلتك
                {% endif %}
            </p>
        </div>
    </div>

    {# ── Two-column layout ───────────────────────────────────── #}
    <div class="lc-cart-layout">

        {# ── Items column ────────────────────────────────────── #}
        <div class="lc-items-col">
            <div class="lc-items-list">

                {% for item in cart_items %}
                <div class="lc-item" data-course-id="{{ item.id }}">

                    {# Thumbnail #}
                    <a href="{{ item.permalink }}" class="lc-item__thumb">
                        <img src="{{ item.thumbnail }}" alt="{{ item.title }}" loading="lazy">
                    </a>

                    {# Body #}
                    <div class="lc-item__body">
                        <h3 class="lc-item__title">
                            <a href="{{ item.permalink }}">{{ item.title }}</a>
                        </h3>
                        <div class="lc-item__meta">
                            {% if item.author %}
                            <span class="lc-item__meta-tag">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
                                </svg>
                                {{ item.author }}
                            </span>
                            {% endif %}
                            {% if item.duration %}
                            <span class="lc-item__meta-tag">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                                </svg>
                                {{ item.duration }}
                            </span>
                            {% endif %}
                            {% if item.level %}
                            <span class="lc-item__meta-tag">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                                </svg>
                                {{ item.level }}
                            </span>
                            {% endif %}
                        </div>
                    </div>

                    {# Side: price + remove ─────────────────────── #}
                    <div class="lc-item__side">
                        <div class="lc-item__price">
                            {% if item.has_sale %}
                            <span class="lc-item__price-old">{{ item.price_old }}</span>
                            {% endif %}
                            <span class="lc-item__price-current">{{ item.price }}</span>
                        </div>
                        <button type="button"
                                class="lc-item__remove"
                                data-course-id="{{ item.id }}"
                                aria-label="حذف الدورة من السلة">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="3 6 5 6 21 6"/>
                                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                                <line x1="10" y1="11" x2="10" y2="17"/>
                                <line x1="14" y1="11" x2="14" y2="17"/>
                            </svg>
                        </button>
                    </div>

                </div>
                {% endfor %}

            </div>
        </div>{# /lc-items-col #}

        {# ── Summary column ──────────────────────────────────── #}
        <div class="lc-summary-col">
            <div class="lc-summary-card">

                <div class="lc-summary-card__header">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/>
                        <line x1="8" y1="18" x2="21" y2="18"/>
                        <line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/>
                        <line x1="3" y1="18" x2="3.01" y2="18"/>
                    </svg>
                    ملخص الطلب
                </div>

                <div class="lc-summary-rows">
                    <div class="lc-summary-row">
                        <span class="lc-summary-row__label">المجموع الفرعي</span>
                        <span class="lc-summary-row__val">{{ fmt_subtotal }}</span>
                    </div>
                    {% if show_tax %}
                    <div class="lc-summary-row">
                        <span class="lc-summary-row__label">{{ tax_label }}</span>
                        <span class="lc-summary-row__val">{{ fmt_tax }}</span>
                    </div>
                    {% endif %}
                </div>

                <div class="lc-summary-total">
                    <span class="lc-summary-total__label">الإجمالي</span>
                    <span class="lc-summary-total__val">{{ fmt_total }}</span>
                </div>

                <a href="{{ checkout_url }}" class="lc-checkout-btn">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14"/><polyline points="12 5 19 12 12 19"/>
                    </svg>
                    إتمام الشراء
                </a>

                {# Trust badges #}
                <div class="lc-trust-badges">
                    <span class="lc-trust-badge">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                        </svg>
                        دفع آمن ومشفر
                    </span>
                    <span class="lc-trust-badge">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                        </svg>
                        وصول مدى الحياة
                    </span>
                    <span class="lc-trust-badge">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="20 6 9 17 4 12"/>
                        </svg>
                        ضمان استرداد 30 يوم
                    </span>
                </div>

            </div>
        </div>{# /lc-summary-col #}

    </div>{# /lc-cart-layout #}

    {% else %}

    {# ── Empty state ─────────────────────────────────────────── #}
    <div class="lc-empty">
        <div class="lc-empty__inner">
            <div class="lc-empty__icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                    <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                </svg>
            </div>
            <h2 class="lc-empty__title">سلتك فارغة</h2>
            <p class="lc-empty__sub">لم تقم بإضافة أي دورة بعد، استعرض دوراتنا وابدأ تعلمك الآن</p>
            <a href="{{ shop_url }}" class="lc-empty__btn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14"/><polyline points="12 5 19 12 12 19"/>
                </svg>
                تصفح الدورات
            </a>
        </div>
    </div>

    {% endif %}

</div>{# /lc-cart #}

{% endblock %}
