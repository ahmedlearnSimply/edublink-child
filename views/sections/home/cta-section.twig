    .ls-cta-trust-text{color:#6b7394;font-size:12px;font-family:"IBM Plex Sans Arabic",sans-serif}

    /* FOMO: badge pulse */
    @keyframes ls-badge-pulse{0%,100%{box-shadow:0 0 0 0 rgba(239,68,68,0.3)}50%{box-shadow:0 0 0 10px rgba(239,68,68,0)}}

    /* FOMO: timer number flip */
    .ls-cta-timer-num.ls-flip{animation:ls-num-flip 0.4s ease-out}
    @keyframes ls-num-flip{0%{transform:translateY(-8px);opacity:0.3}50%{transform:translateY(2px)}100%{transform:translateY(0);opacity:1}}

    /* FOMO: timer urgency red + shake */
    .ls-cta-timer-box.ls-urgent{background:rgba(239,68,68,0.08);border-color:rgba(239,68,68,0.3)}
    .ls-cta-timer-box.ls-urgent .ls-cta-timer-num{color:#ef4444}
    .ls-cta-timer.ls-shake{animation:ls-timer-shake 0.6s ease-in-out}
    @keyframes ls-timer-shake{0%,100%{transform:translateX(0)}15%{transform:translateX(-3px)}30%{transform:translateX(3px)}45%{transform:translateX(-2px)}60%{transform:translateX(2px)}75%{transform:translateX(-1px)}90%{transform:translateX(1px)}}

    /* FOMO: CTA button glow + shine */
    @keyframes ls-btn-glow{0%,100%{box-shadow:0 0 0 0 rgba(64,119,243,0)}50%{box-shadow:0 0 20px 4px rgba(64,119,243,0.3)}}
    .ls-cta-btn-primary::after{content:'';position:absolute;top:0;left:-100%;width:60%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.15),transparent);animation:ls-btn-shine 3s ease-in-out infinite}
    @keyframes ls-btn-shine{0%{left:-100%}50%{left:120%}100%{left:120%}}

    /* FOMO: save badge pulse */
    @keyframes ls-save-pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.05)}}

    /* FOMO: spots left */
    .ls-cta-spots{position:relative;z-index:1;text-align:center;margin-bottom:16px}
    .ls-cta-spots-inner{display:inline-flex;align-items:center;gap:8px;padding:0;background:none;border:none}
    .ls-cta-spots-dot{width:6px;height:6px;border-radius:50%;background:#ef4444;animation:ls-dot-blink 1.5s ease-in-out infinite}
    .ls-cta-spots-text{color:#ef4444;font-size:13px;font-weight:500;font-family:"IBM Plex Sans Arabic",sans-serif}
    @keyframes ls-dot-blink{0%,100%{opacity:1}50%{opacity:0.3}}

    /* FOMO: social proof toast */
    .ls-cta-toast{position:fixed;bottom:24px;right:24px;z-index:9999;background:#1b2133;border:1px solid rgba(255,255,255,0.08);border-radius:12px;padding:12px 18px;display:flex;align-items:center;gap:10px;box-shadow:0 8px 32px rgba(0,0,0,0.4);transform:translateX(120%);opacity:0;transition:transform 0.5s cubic-bezier(0.34,1.56,0.64,1),opacity 0.4s;direction:rtl;font-family:"IBM Plex Sans Arabic",sans-serif;max-width:320px}
    .ls-cta-toast.ls-show{transform:translateX(0);opacity:1}
    .ls-cta-toast-icon{width:32px;height:32px;border-radius:50%;background:rgba(24,169,99,0.12);display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .ls-cta-toast-text{font-size:13px;color:#c8cfe0;line-height:1.5}
    .ls-cta-toast-text strong{color:#fff;font-weight:600}
    .ls-cta-toast-time{font-size:11px;color:#6b7394;margin-top:2px}

    @media(max-width:1024px){.ls-cta{padding:40px 32px}.ls-cta-title{font-size:26px}.ls-cta-timer-box{min-width:70px;padding:14px 6px}.ls-cta-timer-num{font-size:28px}.ls-cta-item{padding:10px 14px}}
    @media(max-width:768px){.ls-cta{padding:32px 20px}.ls-cta-title{font-size:22px}.ls-cta-subtitle{font-size:14px}.ls-cta-timer{gap:8px}.ls-cta-timer-box{min-width:60px;padding:12px 4px;border-radius:10px}.ls-cta-timer-num{font-size:24px}.ls-cta-middle{flex-direction:column;align-items:center;gap:12px}.ls-cta-item{width:100%;max-width:320px}.ls-cta-price-new{font-size:24px}.ls-cta-buttons{flex-direction:column;align-items:center}.ls-cta-btn-primary{width:100%;max-width:340px;justify-content:center;font-size:15px;padding:14px 28px}.ls-cta-btn-secondary{width:100%;max-width:340px;justify-content:center}.ls-cta-trust{gap:16px}.ls-cta-toast{right:12px;left:12px;bottom:16px;max-width:none}}
    @media(max-width:480px){.ls-cta-section .learnsimply-section-container{padding-left:12px;padding-right:12px}.ls-cta{padding:24px 16px;border-radius:16px}.ls-cta-badge{padding:5px 12px}.ls-cta-badge-text{font-size:11px}.ls-cta-title{font-size:19px;line-height:1.5}.ls-cta-subtitle{font-size:13px;margin-bottom:20px}.ls-cta-timer{gap:6px;margin-bottom:24px}.ls-cta-timer-box{min-width:52px;padding:10px 4px;border-radius:8px}.ls-cta-timer-num{font-size:20px}.ls-cta-timer-label{font-size:10px}.ls-cta-item{padding:10px 12px;max-width:100%}.ls-cta-item-text{font-size:13px}.ls-cta-price-row{gap:10px}.ls-cta-price-save{font-size:11px;padding:4px 10px}.ls-cta-price-new{font-size:22px}.ls-cta-price-old{font-size:14px}.ls-cta-btn-primary{font-size:14px;padding:12px 20px;max-width:100%}.ls-cta-btn-secondary{font-size:13px;padding:12px 16px;max-width:100%}.ls-cta-trust{gap:12px;flex-direction:column;align-items:center}.ls-cta-glow{width:200px;height:200px}}
    </style>
