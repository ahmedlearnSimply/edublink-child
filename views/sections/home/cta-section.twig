<!-- ===== START: CTA Bundle Section ===== -->
    {% if promo_banner_enabled|default(false) %}
    <style>
    .ls-cta-section{padding:0}
    .ls-cta-section .learnsimply-section-container{padding-top:20px;padding-bottom:20px}
    .ls-cta{position:relative;background:#0d1220;border-radius:20px;overflow:hidden;padding:48px 44px;direction:rtl;font-family:"IBM Plex Sans Arabic",sans-serif}
    .ls-cta-glow{position:absolute;border-radius:50%;filter:blur(120px);pointer-events:none}
    .ls-cta-glow-1{width:350px;height:350px;background:#4077f3;opacity:0.12;top:-80px;right:-40px}
    .ls-cta-glow-2{width:300px;height:300px;background:#f0a030;opacity:0.06;bottom:-120px;left:-60px}
    .ls-cta-top{position:relative;z-index:1;text-align:center;margin-bottom:32px}
    .ls-cta-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.25);border-radius:100px;padding:6px 18px;margin-bottom:16px;animation:ls-badge-pulse 2s ease-in-out infinite}
    .ls-cta-badge-fire{font-size:14px}
    .ls-cta-badge-text{color:#ef4444;font-size:13px;font-weight:600;font-family:"IBM Plex Sans Arabic",sans-serif}
    .ls-cta-title{color:#fff;font-size:30px;font-weight:700;line-height:1.6;margin:0 0 10px;font-family:"IBM Plex Sans Arabic",sans-serif}
    .ls-cta-title span{background:linear-gradient(135deg,#4077f3,#60a5fa);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
    .ls-cta-subtitle{color:#8893b0;font-size:15px;line-height:1.7;margin:0 auto 28px;max-width:600px;font-family:"IBM Plex Sans Arabic",sans-serif}
    .ls-cta-timer{display:flex;justify-content:center;gap:12px;margin-bottom:32px}
    .ls-cta-timer-box{background:rgba(64,119,243,0.08);border:1px solid rgba(64,119,243,0.2);border-radius:14px;padding:16px 8px;min-width:80px;text-align:center;transition:background 0.4s,border-color 0.4s}
    .ls-cta-timer-num{color:#fff;font-size:32px;font-weight:700;line-height:1;margin-bottom:4px;font-variant-numeric:tabular-nums;font-family:"IBM Plex Sans Arabic",sans-serif;transition:transform 0.3s,color 0.3s}
    .ls-cta-timer-label{color:#6b7394;font-size:12px;font-weight:400;font-family:"IBM Plex Sans Arabic",sans-serif}
    .ls-cta-middle{position:relative;z-index:1;display:flex;gap:20px;justify-content:center;margin-bottom:32px;flex-wrap:wrap}
    .ls-cta-item{display:flex;align-items:center;gap:10px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);border-radius:12px;padding:12px 18px;flex:0 1 auto}
    .ls-cta-item-icon{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .ls-cta-item-icon.blue{background:rgba(64,119,243,0.12)}
    .ls-cta-item-icon.green{background:rgba(24,169,99,0.12)}
    .ls-cta-item-icon.amber{background:rgba(240,160,48,0.12)}
    .ls-cta-item-text{font-size:14px;color:#c8cfe0;font-weight:500;font-family:"IBM Plex Sans Arabic",sans-serif}
    .ls-cta-item-sub{font-size:11px;color:#6b7394;font-weight:400;font-family:"IBM Plex Sans Arabic",sans-serif}
    .ls-cta-price-row{position:relative;z-index:1;display:flex;justify-content:center;align-items:center;gap:16px;margin-bottom:10px;flex-wrap:wrap}
    .ls-cta-price-save{background:rgba(24,169,99,0.12);color:#18A963;font-size:13px;font-weight:600;padding:6px 14px;border-radius:8px;font-family:"IBM Plex Sans Arabic",sans-serif;animation:ls-save-pulse 2s ease-in-out infinite 0.5s}
    .ls-cta-price-new{color:#fff;font-size:28px;font-weight:700;font-family:"IBM Plex Sans Arabic",sans-serif}
    .ls-cta-price-old{color:#6b7394;font-size:16px;text-decoration:line-through;font-family:"IBM Plex Sans Arabic",sans-serif}
    .ls-cta-price-note{color:#6b7394;font-size:12px;text-align:center;margin:0 0 24px;position:relative;z-index:1;font-family:"IBM Plex Sans Arabic",sans-serif}
    .ls-cta-buttons{position:relative;z-index:1;display:flex;justify-content:center;gap:12px;flex-wrap:wrap}
    .ls-cta-btn-primary{display:inline-flex;align-items:center;gap:8px;background:linear-gradient(135deg,#4077f3,#2563eb);color:#fff;font-size:16px;font-weight:600;padding:16px 36px;border-radius:12px;text-decoration:none;border:none;cursor:pointer;transition:transform 0.2s,box-shadow 0.2s;font-family:"IBM Plex Sans Arabic",sans-serif;position:relative;overflow:hidden;animation:ls-btn-glow 2.5s ease-in-out infinite}
    .ls-cta-btn-primary:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(64,119,243,0.35);color:#fff;text-decoration:none}
    .ls-cta-btn-secondary{display:inline-flex;align-items:center;gap:6px;background:transparent;color:#8893b0;font-size:14px;font-weight:400;padding:16px 24px;border-radius:12px;text-decoration:none;border:1px solid rgba(255,255,255,0.1);transition:border-color 0.2s,color 0.2s;font-family:"IBM Plex Sans Arabic",sans-serif}
    .ls-cta-btn-secondary:hover{border-color:rgba(255,255,255,0.25);color:#fff;text-decoration:none}
    .ls-cta-trust{position:relative;z-index:1;display:flex;justify-content:center;gap:24px;margin-top:24px;flex-wrap:wrap}
    .ls-cta-trust-item{display:flex;align-items:center;gap:6px}
