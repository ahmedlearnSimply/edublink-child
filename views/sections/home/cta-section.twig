        </div>
        <div>
          <div class="ls-cta-toast-text" id="ls-cta-toast-text"></div>
          <div class="ls-cta-toast-time" id="ls-cta-toast-time"></div>
        </div>
      </div>

      <script>
      (function(){
        var deadlineMs = typeof learnsimplyPromoDeadline !== 'undefined' ? parseInt(learnsimplyPromoDeadline) : 0;
        if(!deadlineMs){
          var fallback = new Date();
          fallback.setDate(fallback.getDate() + 3);
          fallback.setHours(23,59,59,0);
          deadlineMs = fallback.getTime();
        }
        function pad(n){ return String(n).padStart(2,'0'); }

        var prevVals = {d:'',h:'',m:'',s:''};

        function tick(){
          var diff = deadlineMs - Date.now();
          if(diff <= 0){
            document.getElementById('ls-cta-days').textContent='00';
            document.getElementById('ls-cta-hours').textContent='00';
            document.getElementById('ls-cta-mins').textContent='00';
            document.getElementById('ls-cta-secs').textContent='00';
            return;
          }

          var d = pad(Math.floor(diff/(1000*60*60*24)));
          var h = pad(Math.floor((diff%(1000*60*60*24))/(1000*60*60)));
          var m = pad(Math.floor((diff%(1000*60*60))/(1000*60)));
          var s = pad(Math.floor((diff%(1000*60))/1000));

          function updateEl(id, val, key){
            var el = document.getElementById(id);
            if(prevVals[key] !== val){
              el.textContent = val;
              el.classList.remove('ls-flip');
              void el.offsetWidth;
              el.classList.add('ls-flip');
              prevVals[key] = val;
            }
          }
          updateEl('ls-cta-days',d,'d');
          updateEl('ls-cta-hours',h,'h');
          updateEl('ls-cta-mins',m,'m');
          updateEl('ls-cta-secs',s,'s');

          var underOneDay = parseInt(d) === 0;
          var boxes = document.querySelectorAll('.ls-cta-timer-box');
          boxes.forEach(function(b){ b.classList.toggle('ls-urgent', underOneDay); });
        }
        tick();
        setInterval(tick, 1000);

        setInterval(function(){
          var d = document.getElementById('ls-cta-days').textContent;
          var h = document.getElementById('ls-cta-hours').textContent;
          if(d === '00' && h === '00'){
            var timer = document.getElementById('ls-cta-timer');
            timer.classList.remove('ls-shake');
            void timer.offsetWidth;
            timer.classList.add('ls-shake');
          }
        }, 30000);

        var names = ['أحمد م.','سارة ك.','محمد ع.','نور الدين','فاطمة ح.','عمر ي.','مريم ت.','خالد ج.','ريم س.','يوسف ب.','هدى ن.','إبراهيم ل.','لينا ز.','كريم ف.','دينا ش.'];
        var times = ['منذ دقيقتين','منذ 5 دقائق','منذ 8 دقائق','منذ 12 دقيقة','منذ 15 دقيقة','منذ نصف ساعة','منذ ساعة'];
        var toast = document.getElementById('ls-cta-toast');
        var toastText = document.getElementById('ls-cta-toast-text');
        var toastTime = document.getElementById('ls-cta-toast-time');
        var toastIndex = 0;

        function shuffleArray(arr){
          for(var i=arr.length-1;i>0;i--){var j=Math.floor(Math.random()*(i+1));var t=arr[i];arr[i]=arr[j];arr[j]=t;}
        }
        shuffleArray(names);

        function showToast(){
          var name = names[toastIndex % names.length];
          var time = times[Math.floor(Math.random()*times.length)];
          toastText.innerHTML = '<strong>' + name + '</strong> اشترك في حزمة Java الكاملة';
          toastTime.textContent = time;
          toast.classList.add('ls-show');
          toastIndex++;
          setTimeout(function(){ toast.classList.remove('ls-show'); }, 4000);
        }

        setTimeout(function(){
          showToast();
          (function scheduleNext(){
            var delay = 25000 + Math.floor(Math.random() * 20000);
            setTimeout(function(){ showToast(); scheduleNext(); }, delay);
          })();
        }, 8000);

      })();
      </script>
