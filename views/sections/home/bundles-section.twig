<!-- ===== START: Bundles Section ===== -->
    <style>
    .ls-bundles-section{padding:80px 0}
    .ls-bundles-container{max-width:1100px;margin:0 auto;padding:0 24px}
    .ls-bundles-header{text-align:center;margin-bottom:56px}
    .ls-bundles-label{display:inline-flex;align-items:center;gap:6px;background:rgba(64,119,243,0.08);border:1px solid rgba(64,119,243,0.15);border-radius:100px;padding:6px 16px;margin-bottom:20px;font-size:13px;color:#4077f3;font-weight:500;font-family:"IBM Plex Sans Arabic",sans-serif}
    .ls-bundles-label-dot{width:5px;height:5px;border-radius:50%;background:#4077f3}
    .ls-bundles-title{font-size:36px;font-weight:700;line-height:1.5;margin-bottom:12px;color:#fff;font-family:"IBM Plex Sans Arabic",sans-serif}
    .ls-bundles-subtitle{font-size:15px;color:#8893b0;line-height:1.7;max-width:500px;margin:0 auto;font-family:"IBM Plex Sans Arabic",sans-serif}
    .ls-bundle-card{position:relative;background:#0d1220;border-radius:24px;overflow:hidden;border:1px solid rgba(255,255,255,0.04)}
    .ls-bundle-card::before{content:'';position:absolute;width:400px;height:400px;background:radial-gradient(circle,rgba(64,119,243,0.08) 0%,transparent 70%);top:-100px;right:-50px;pointer-events:none}
    .ls-bundle-inner{display:grid;grid-template-columns:1fr 1fr;gap:0;position:relative;z-index:1}
    .ls-bundle-content{padding:48px 44px;display:flex;flex-direction:column;justify-content:center;font-family:"IBM Plex Sans Arabic",sans-serif}
    .ls-bundle-tag{display:inline-flex;align-items:center;gap:6px;background:rgba(240,160,48,0.1);border:1px solid rgba(240,160,48,0.2);border-radius:8px;padding:4px 12px;font-size:12px;color:#f0a030;font-weight:600;width:fit-content;margin-bottom:16px;letter-spacing:0.3px}
    .ls-bundle-name{font-size:24px;font-weight:700;color:#fff;line-height:1.5;margin-bottom:8px;font-family:"IBM Plex Sans Arabic",sans-serif}
    .ls-bundle-name span{color:#4077f3}
    .ls-bundle-desc{font-size:14px;color:#8893b0;line-height:1.8;margin-bottom:28px;max-width:420px;font-family:"IBM Plex Sans Arabic",sans-serif}
    .ls-bundle-instructor{display:flex;align-items:center;gap:10px;margin-bottom:28px}
    .ls-bundle-instructor-avatar{width:36px;height:36px;border-radius:50%;border:2px solid rgba(64,119,243,0.3);overflow:hidden;flex-shrink:0;background:#1b2133}
    .ls-bundle-instructor-avatar img{width:100%;height:100%;object-fit:cover}
    .ls-bundle-instructor-name{font-size:13px;color:#c8cfe0;font-weight:500}
    .ls-bundle-instructor-role{font-size:11px;color:#6b7394}
    .ls-bundle-items{display:flex;flex-direction:column;gap:10px;margin-bottom:32px}
    .ls-bundle-item{display:flex;align-items:center;gap:10px}
    .ls-bundle-item-check{width:20px;height:20px;border-radius:50%;background:rgba(24,169,99,0.12);display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .ls-bundle-item-text{font-size:14px;color:#c8cfe0;font-weight:400;font-family:"IBM Plex Sans Arabic",sans-serif}
    .ls-bundle-price-area{display:flex;align-items:center;gap:16px;margin-bottom:24px;flex-wrap:wrap}
    .ls-bundle-price-new{font-size:32px;font-weight:700;color:#fff;font-family:"IBM Plex Sans Arabic",sans-serif}
    .ls-bundle-price-old{font-size:16px;color:#6b7394;text-decoration:line-through;font-family:"IBM Plex Sans Arabic",sans-serif}
    .ls-bundle-price-save{background:rgba(24,169,99,0.1);color:#18A963;font-size:12px;font-weight:600;padding:4px 12px;border-radius:6px;font-family:"IBM Plex Sans Arabic",sans-serif}
    .ls-bundle-actions{display:flex;gap:12px;flex-wrap:wrap}
    .ls-bundle-btn-primary{display:inline-flex;align-items:center;gap:8px;background:linear-gradient(135deg,#4077f3,#2563eb);color:#fff;font-size:15px;font-weight:600;padding:14px 32px;border-radius:12px;text-decoration:none;border:none;cursor:pointer;transition:transform 0.2s,box-shadow 0.2s;position:relative;overflow:hidden;font-family:"IBM Plex Sans Arabic",sans-serif}
    .ls-bundle-btn-primary:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(64,119,243,0.3);color:#fff;text-decoration:none}
    .ls-bundle-btn-primary::after{content:'';position:absolute;top:0;left:-100%;width:60%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.12),transparent);animation:ls-bundle-shine 3.5s ease-in-out infinite}
    @keyframes ls-bundle-shine{0%{left:-100%}50%{left:120%}100%{left:120%}}
    .ls-bundle-btn-secondary{display:inline-flex;align-items:center;gap:6px;background:transparent;color:#8893b0;font-size:14px;font-weight:400;padding:14px 20px;border-radius:12px;text-decoration:none;border:1px solid rgba(255,255,255,0.08);transition:border-color 0.2s,color 0.2s;font-family:"IBM Plex Sans Arabic",sans-serif}
    .ls-bundle-btn-secondary:hover{border-color:rgba(255,255,255,0.2);color:#fff;text-decoration:none}
    .ls-bundle-visual{position:relative;background:linear-gradient(135deg,#0a0f1a 0%,#111827 100%);display:flex;align-items:center;justify-content:center;padding:40px;overflow:hidden;min-height:420px}
    .ls-bundle-visual::after{content:'';position:absolute;inset:0;background-image:radial-gradient(rgba(255,255,255,0.03) 1px,transparent 1px);background-size:24px 24px;pointer-events:none}
    .ls-bundle-covers{position:relative;width:100%;max-width:360px;height:300px}
    .ls-bundle-cover{position:absolute;border-radius:16px;overflow:hidden;box-shadow:0 16px 48px rgba(0,0,0,0.4);transition:transform 0.4s cubic-bezier(0.34,1.56,0.64,1);border:2px solid rgba(255,255,255,0.06)}
    .ls-bundle-cover img{width:100%;height:100%;object-fit:cover;display:block}
    .ls-bundle-cover:hover{transform:translateY(-8px) scale(1.03)!important}
    .ls-bundle-cover-1{width:220px;height:140px;top:0;right:0;z-index:3;transform:rotate(-2deg)}
    .ls-bundle-cover-2{width:200px;height:130px;top:100px;right:120px;z-index:2;transform:rotate(3deg)}
    .ls-bundle-cover-3{width:180px;height:120px;top:180px;right:20px;z-index:1;transform:rotate(-1deg)}
    .ls-bundle-stat{position:absolute;background:rgba(13,18,32,0.9);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,0.08);border-radius:12px;padding:10px 14px;display:flex;align-items:center;gap:8px;z-index:10;font-family:"IBM Plex Sans Arabic",sans-serif}
    .ls-bundle-stat-1{bottom:20px;left:20px}
    .ls-bundle-stat-2{top:20px;left:40px}
    .ls-bundle-stat-icon{width:28px;height:28px;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .ls-bundle-stat-icon.orange{background:rgba(240,160,48,0.12)}
    .ls-bundle-stat-icon.green{background:rgba(24,169,99,0.12)}
    .ls-bundle-stat-value{font-size:14px;font-weight:600;color:#fff}
    .ls-bundle-stat-label{font-size:11px;color:#6b7394}
    .ls-bundle-trust{display:flex;justify-content:center;gap:32px;margin-top:24px;flex-wrap:wrap}
    .ls-bundle-trust-item{display:flex;align-items:center;gap:6px}
    .ls-bundle-trust-item svg{flex-shrink:0}
    .ls-bundle-trust-text{color:#6b7394;font-size:12px;font-family:"IBM Plex Sans Arabic",sans-serif}
    .ls-bundles-view-all{display:block;width:fit-content;margin:48px auto 0;padding:14px 32px;border-radius:12px;border:1px solid rgba(255,255,255,0.08);background:transparent;color:#8893b0;font-size:14px;font-weight:500;text-decoration:none;transition:border-color 0.2s,color 0.2s;font-family:"IBM Plex Sans Arabic",sans-serif}
    .ls-bundles-view-all:hover{border-color:rgba(255,255,255,0.2);color:#fff;text-decoration:none}
    @media(max-width:900px){.ls-bundle-inner{grid-template-columns:1fr}.ls-bundle-visual{min-height:300px;order:-1}.ls-bundle-content{padding:32px 28px}.ls-bundle-covers{max-width:300px;height:240px}.ls-bundle-cover-1{width:180px;height:115px}.ls-bundle-cover-2{width:165px;height:108px;top:80px;right:90px}.ls-bundle-cover-3{width:150px;height:100px;top:145px;right:10px}.ls-bundles-title{font-size:28px}}
    @media(max-width:600px){.ls-bundles-section{padding:56px 0}.ls-bundles-title{font-size:24px}.ls-bundle-content{padding:24px 20px}.ls-bundle-name{font-size:20px}.ls-bundle-price-new{font-size:26px}.ls-bundle-visual{min-height:240px;padding:28px}.ls-bundle-covers{max-width:260px;height:200px}.ls-bundle-cover-1{width:160px;height:100px}.ls-bundle-cover-2{width:145px;height:95px;top:65px;right:75px}.ls-bundle-cover-3{width:130px;height:85px;top:120px;right:10px}.ls-bundle-stat{padding:8px 10px}.ls-bundle-stat-value{font-size:12px}.ls-bundle-actions{flex-direction:column}.ls-bundle-btn-primary{width:100%;justify-content:center}.ls-bundle-btn-secondary{width:100%;justify-content:center}.ls-bundle-trust{gap:16px;flex-direction:column;align-items:center}}
    </style>

    <section id="bundles" class="ls-bundles-section">
      <div class="ls-bundles-container">

        <div class="ls-bundles-header">
          <div class="ls-bundles-label">
            <span class="ls-bundles-label-dot"></span>
            <span>الباقات</span>
          </div>
          <h2 class="ls-bundles-title">وفّر أكتر… واتعلم أسرع<br>مع الباقات الكاملة</h2>
          <p class="ls-bundles-subtitle">باقة متكاملة بتاخدك من الأساسيات لحد الاحتراف</p>
        </div>

        <div class="ls-bundle-card">
          <div class="ls-bundle-inner">

            <div class="ls-bundle-content">
              <div class="ls-bundle-tag">👑 الباقة الأكثر مبيعاً</div>

              <h3 class="ls-bundle-name">كورس <span>Java Basics + OOP</span><br>من الأساسيات إلى الاحتراف</h3>

              <p class="ls-bundle-desc">3 دورات في باقة واحدة — كل اللي محتاجه عشان تبني أساس برمجي صح من أول يوم.</p>

              <div class="ls-bundle-instructor">
                <div class="ls-bundle-instructor-avatar">
                  {% if bundles is defined and bundles|length > 0 and bundles[0].author_avatar %}
                    <img src="{{ bundles[0].author_avatar }}" alt="م. أحمد عادل">
                  {% else %}
                    <img src="{{ theme_uri }}/assets/img/card_image.png" alt="م. أحمد عادل">
                  {% endif %}
                </div>
                <div>
                  <div class="ls-bundle-instructor-name">م. أحمد عادل</div>
                  <div class="ls-bundle-instructor-role">{{ instructor_title }}</div>
                </div>
              </div>

              <div class="ls-bundle-items">
                <div class="ls-bundle-item">
                  <div class="ls-bundle-item-check">
                    <svg width="10" height="10" viewBox="0 0 20 20" fill="none"><path d="M16.667 5L7.5 14.167 3.333 10" stroke="#18A963" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </div>
                  <span class="ls-bundle-item-text">كورس Java Basics — من الصفر للمتوسط</span>
                </div>
                <div class="ls-bundle-item">
                  <div class="ls-bundle-item-check">
                    <svg width="10" height="10" viewBox="0 0 20 20" fill="none"><path d="M16.667 5L7.5 14.167 3.333 10" stroke="#18A963" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </div>
                  <span class="ls-bundle-item-text">كورس OOP المتقدم — برمجة كائنية احترافية</span>
                </div>
                <div class="ls-bundle-item">
                  <div class="ls-bundle-item-check">
                    <svg width="10" height="10" viewBox="0 0 20 20" fill="none"><path d="M16.667 5L7.5 14.167 3.333 10" stroke="#18A963" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </div>
                  <span class="ls-bundle-item-text">كتاب PDF مجاني — ملخصات + تمارين</span>
                </div>
              </div>

              <div class="ls-bundle-price-area">
                <span class="ls-bundle-price-new">849 ج.م</span>
                <span class="ls-bundle-price-old">2,150 ج.م</span>
                <span class="ls-bundle-price-save">وفّر 61%</span>
              </div>

              <div class="ls-bundle-actions">
                <a class="ls-bundle-btn-primary" href="{{ cart_url|default(site.url ~ '/cart-1/') }}?add-to-cart=33336">
                  <span>اشترك في الباقة</span>
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
                <a class="ls-bundle-btn-secondary" href="{{ site.url }}/product/java-basics-oop-bundle/">
                  <span>تفاصيل الباقة</span>
                </a>
              </div>
            </div>

            <div class="ls-bundle-visual">
              <div class="ls-bundle-covers">
            <div class="ls-bundle-cover ls-bundle-cover-1">
                    <div style="width:100%;height:100%;background:linear-gradient(135deg,#1a2744,#0d1832);display:flex;align-items:center;justify-content:center;font-size:13px;color:#4077f3;font-weight:600;text-align:center;padding:12px;font-family:'IBM Plex Sans Arabic',sans-serif">Java Basics<br><span style="font-size:11px;color:#6b7394;font-weight:400">Level One</span></div>
                  </div>
                  <div class="ls-bundle-cover ls-bundle-cover-2">
                    <div style="width:100%;height:100%;background:linear-gradient(135deg,#1a2744,#0d1832);display:flex;align-items:center;justify-content:center;font-size:13px;color:#18A963;font-weight:600;text-align:center;padding:12px;font-family:'IBM Plex Sans Arabic',sans-serif">Java OOP<br><span style="font-size:11px;color:#6b7394;font-weight:400">Level Two</span></div>
                  </div>
                  <div class="ls-bundle-cover ls-bundle-cover-3">
                    <div style="width:100%;height:100%;background:linear-gradient(135deg,#1a2744,#0d1832);display:flex;align-items:center;justify-content:center;font-size:13px;color:#f0a030;font-weight:600;text-align:center;padding:12px;font-family:'IBM Plex Sans Arabic',sans-serif">PDF Book<br><span style="font-size:11px;color:#6b7394;font-weight:400">ملخصات</span></div>
                  </div>
              </div>

              <div class="ls-bundle-stat ls-bundle-stat-1">
                <div class="ls-bundle-stat-icon orange">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M12 2l2.9 6.26L21.9 9.27l-5 3.86L18 21l-6-3.16L6 21l1.1-7.87-5-3.86 6.99-0.99L12 2z" fill="#f0a030"/></svg>
                </div>
                <div>
                  <div class="ls-bundle-stat-value">5.0 تقييم</div>
                  <div class="ls-bundle-stat-label">من الطلاب</div>
                </div>
              </div>
              <div class="ls-bundle-stat ls-bundle-stat-2">
                <div class="ls-bundle-stat-icon green">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2" stroke="#18A963" stroke-width="1.5"/><circle cx="9" cy="7" r="4" stroke="#18A963" stroke-width="1.5"/><path d="M22 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="#18A963" stroke-width="1.5"/></svg>
                </div>
                <div>
                  <div class="ls-bundle-stat-value">+1000 طالب</div>
                  <div class="ls-bundle-stat-label">مشترك</div>
                </div>
              </div>
            </div>

          </div>
        </div>

        <div class="ls-bundle-trust">
          <div class="ls-bundle-trust-item">
            <svg width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M16.667 5L7.5 14.167 3.333 10" stroke="#18A963" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span class="ls-bundle-trust-text">ضمان استرداد المبلغ</span>
          </div>
          <div class="ls-bundle-trust-item">
            <svg width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M16.667 5L7.5 14.167 3.333 10" stroke="#18A963" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span class="ls-bundle-trust-text">وصول مدى الحياة</span>
          </div>
          <div class="ls-bundle-trust-item">
            <svg width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M16.667 5L7.5 14.167 3.333 10" stroke="#18A963" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span class="ls-bundle-trust-text">3 دورات في باقة واحدة</span>
          </div>
        </div>

        <a href="{{ site.url }}/shop-2/?product_cat=bundle" class="ls-bundles-view-all">عرض كل الباقات</a>

      </div>
    </section>
    <!-- ===== END: Bundles Section ===== -->