          <div class="ls-path-chips">
            <span class="ls-path-chip">
              <svg class="ls-path-check" viewBox="0 0 20 20" fill="none">
                <path d="M16.667 5L7.5 14.167 3.333 10" stroke="#18A963" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
