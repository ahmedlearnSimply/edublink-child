<!-- ===== START: Learning Path Section ===== -->
<style>
  .ls-path {
    padding: 86px 0;
    direction: rtl;
    font-family: "IBM Plex Sans Arabic", sans-serif;
  }

  .ls-path * {
    box-sizing: border-box;
  }

  .ls-path-container {
    max-width: 1040px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .ls-path-header {
    text-align: center;
    margin-bottom: 54px;
  }

  .ls-path-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 17px;
    margin-bottom: 18px;
    border-radius: 999px;
    background: rgba(64, 119, 243, 0.09);
    border: 1px solid rgba(64, 119, 243, 0.18);
    color: #6f9cff;
    font-size: 13px;
    font-weight: 600;
  }

  .ls-path-badge-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #4077f3;
    box-shadow: 0 0 16px rgba(64, 119, 243, 0.9);
  }

  .ls-path-title {
    margin: 0 0 14px;
    color: #ffffff;
    font-size: 38px;
    font-weight: 800;
    line-height: 1.45;
    letter-spacing: -0.5px;
  }

  .ls-path-subtitle {
    max-width: 650px;
    margin: 0 auto;
    color: #9aa6c2;
    font-size: 16px;
    line-height: 1.9;
  }

  .ls-path-list {
    position: relative;
    display: grid;
    gap: 22px;
  }

  .ls-path-item {
    position: relative;
    display: grid;
    grid-template-columns: 58px 1fr;
    gap: 22px;
    align-items: stretch;
  }

  .ls-path-track {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .ls-path-number {
    position: relative;
    z-index: 2;
    width: 50px;
    height: 50px;
    display: grid;
    place-items: center;
    border-radius: 18px;
    color: #ffffff;
    font-size: 20px;
    font-weight: 800;
    box-shadow: 0 14px 34px rgba(0, 0, 0, 0.22);
  }

  .ls-path-number.java {
    background: linear-gradient(135deg, #f0a030, #e87722);
  }

  .ls-path-number.dsa {
    background: linear-gradient(135deg, #18a963, #0f8f52);
  }

  .ls-path-item:not(:last-child) .ls-path-track::after {
    content: "";
    position: absolute;
    top: 58px;
    bottom: -22px;
    width: 2px;
    border-radius: 99px;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.18),
      rgba(255, 255, 255, 0.03)
    );
  }

  .ls-path-card {
    position: relative;
    overflow: hidden;
    padding: 28px;
    border-radius: 22px;
    background:
      radial-gradient(circle at top left, rgba(255, 255, 255, 0.055), transparent 34%),
      linear-gradient(180deg, #111827, #0b1020);
    border: 1px solid rgba(255, 255, 255, 0.075);
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
  }

  .ls-path-card:hover {
    transform: translateY(-4px);
    border-color: rgba(255, 255, 255, 0.14);
    box-shadow: 0 18px 46px rgba(0, 0, 0, 0.24);
  }

  .ls-path-card::before {
    content: "";
    position: absolute;
    inset-inline-start: 0;
    top: 0;
    width: 4px;
    height: 100%;
    opacity: 0.95;
  }

  .ls-path-card.java::before {
    background: linear-gradient(180deg, #f0a030, #e87722);
  }

  .ls-path-card.dsa::before {
    background: linear-gradient(180deg, #18a963, #0f8f52);
  }

  .ls-path-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 14px;
  }

  .ls-path-tag {
    display: inline-flex;
    align-items: center;
    padding: 5px 12px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 700;
  }

  .ls-path-tag.java {
    background: rgba(240, 160, 48, 0.12);
    color: #f7b955;
  }

  .ls-path-tag.dsa {
    background: rgba(24, 169, 99, 0.12);
    color: #36d786;
  }

  .ls-path-note {
    color: #7f8baa;
    font-size: 13px;
    font-weight: 500;
  }

  .ls-path-card-title {
    margin: 0 0 10px;
    color: #ffffff;
    font-size: 22px;
    font-weight: 800;
    line-height: 1.5;
  }

  .ls-path-card-desc {
    max-width: 760px;
    margin: 0 0 18px;
    color: #9aa6c2;
    font-size: 15px;
    line-height: 1.9;
  }

  .ls-path-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 22px;
  }

  .ls-path-chip {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 8px 13px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.045);
    border: 1px solid rgba(255, 255, 255, 0.075);
    color: #d7deef;
    font-size: 13px;
    font-weight: 600;
  }

  .ls-path-check {
    width: 15px;
    height: 15px;
    flex: 0 0 auto;
  }

  .ls-path-link {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    width: fit-content;
    padding: 11px 16px;
    border-radius: 14px;
    text-decoration: none;
    font-size: 14px;
    font-weight: 800;
    transition: gap 0.2s ease, transform 0.2s ease, background 0.2s ease;
  }

  .ls-path-link:hover {
    gap: 13px;
    transform: translateY(-1px);
    text-decoration: none;
  }

  .ls-path-link.java {
    color: #ffbf60;
    background: rgba(240, 160, 48, 0.1);
  }

  .ls-path-link.java:hover {
    background: rgba(240, 160, 48, 0.16);
    color: #ffd28a;
  }

  .ls-path-link.dsa {
    color: #3ce08d;
    background: rgba(24, 169, 99, 0.1);
  }

  .ls-path-link.dsa:hover {
    background: rgba(24, 169, 99, 0.16);
    color: #63f2a7;
  }

  .ls-path-arrow {
    transform: scaleX(-1);
  }

  @media (max-width: 768px) {
    .ls-path {
      padding: 62px 0;
    }

    .ls-path-title {
      font-size: 28px;
    }

    .ls-path-subtitle {
      font-size: 14px;
    }

    .ls-path-item {
      grid-template-columns: 44px 1fr;
      gap: 14px;
    }

    .ls-path-number {
      width: 40px;
      height: 40px;
      border-radius: 14px;
      font-size: 16px;
    }

    .ls-path-item:not(:last-child) .ls-path-track::after {
      top: 48px;
    }

    .ls-path-card {
      padding: 22px 18px;
      border-radius: 18px;
    }

    .ls-path-card-title {
      font-size: 19px;
    }

    .ls-path-card-desc {
      font-size: 14px;
    }
  }

  @media (max-width: 480px) {
    .ls-path-container {
      padding: 0 16px;
    }

    .ls-path-top {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>

<section class="ls-path">
  <div class="ls-path-container">

    <div class="ls-path-header">
