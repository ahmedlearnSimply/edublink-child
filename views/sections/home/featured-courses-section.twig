<!-- ===== START: Featured Courses Section ===== -->
    <section id="courses" class="learnsimply-featured-courses-section">
      <div class="learnsimply-section-container">
        <div class="learnsimply-section-header">
          <h2 class="learnsimply-section-title">المسارات اللي هتبني أساسك صح</h2>
        </div>
        <p class="learnsimply-section-description">
          ابدأ بالأساسيات، طبّق بإيدك، واطلع من كل مستوى وانت فاهم بجد.
        </p>

        <div class="learnsimply-courses-grid">

 {# ── Premium Bundle Cards (First Positions) ── #}
          {% for bundle in bundles %}
          <article class="course-card bundle-card-premium">
            <div class="bundle-premium-badge">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="#f0a030"><path d="M12 2l2.9 6.26L21.9 9.27l-5 3.86L18 21l-6-3.16L6 21l1.1-7.87-5-3.86 6.99-0.99L12 2z"/></svg>
              <span>باقة مميزة</span>
            </div>

            <div class="course-image bundle-image">
              <a href="{{ bundle.link }}">
                <img src="{{ bundle.thumbnail }}" alt="{{ bundle.title }}" />
                <div class="bundle-image-overlay">
                  <span class="bundle-items-count">{{ bundle.bundle_items_count }} دورات في باقة واحدة</span>
                </div>
              </a>
            </div>

            <div class="course-header">
              <div class="instructor-info">
                <div class="instructor-text">
                  <p class="name">{{ bundle.author_name|default('م. احمد عادل') }}</p>
                  <p class="title">{{ instructor_title }}</p>
                </div>
                <div class="instructor-avatar">
                  <div class="avatar-glow avatar-glow-1"></div>
                  <div class="avatar-glow avatar-glow-2"></div>
                  {% if bundle.author_avatar %}
                    <img src="{{ bundle.author_avatar }}" alt="Instructor" />
                  {% else %}
                    <img src="{{ theme_uri }}/assets/img/card_image.png" alt="Instructor" />
                  {% endif %}
                </div>
              </div>
              <div class="course-badge bundle-badge-tag">
                <p>👑 باقة</p>
              </div>
            </div>

            <div class="course-title">
              <a href="{{ bundle.link }}" class="stretched-link"><p>{{ bundle.title }}</p></a>
            </div>

            <div class="review-students">
              <div class="review">
                <svg class="star-icon" fill="none" viewBox="0 0 24 24">
                  <path d="M12 2l2.9 6.26L21.9 9.27l-5 3.86L18 21l-6-3.16L6 21l1.1-7.87-5-3.86 6.99-0.99L12 2z" fill="#FFBB54" />
                </svg>
                <p>{{ bundle.rating_avg }} ({{ bundle.rating_count }} تقييم)</p>
              </div>
            </div>

            <div class="price-section">
              {% if bundle.discount_percent > 0 %}
                <div class="discount-badge bundle-discount">
                  <p>وفّر {{ bundle.discount_percent }}%</p>
                </div>
              {% endif %}
              <div class="price-display">
                {% if bundle.regular_price and bundle.sale_price %}
                  <p class="new-price">{{ bundle.sale_price|number_format(2, '.', ',') }} جنيه مصري</p>
                  <p class="old-price">{{ bundle.regular_price|number_format(2, '.', ',') }} جنيه مصري</p>
                {% else %}
                  <p class="new-price">{{ bundle.price|number_format(2, '.', ',') }} جنيه مصري</p>
                {% endif %}
              </div>
            </div>

            <div class="action-buttons">
              <a href="{{ bundle.link }}" class="learnsimply-buy-now-button buy-button bundle-btn">
                <span>اشترك في الباقة</span>
              </a>
            </div>
          </article>
          {% endfor %}

          {# ── Regular Course Cards ── #}
          {% for course in courses %}
          <article class="course-card">
            <div class="course-image">
              <a href="{{ course.link }}">
                <img src="{{ course.thumbnail }}" alt="{{ course.title }}" />
              </a>
            </div>

            <div class="course-header">
              <div class="instructor-info">
                <div class="instructor-text">
                  {% if course.instructor %}
                    <p class="name">{{ course.instructor.display_name }}</p>
                    <p class="title">{{ course.instructor.job_title|default(instructor_title) }}</p>
                  {% else %}
                    <p class="name">م. احمد عادل</p>
                    <p class="title">{{ instructor_title }}</p>
                  {% endif %}
                </div>
                <div class="instructor-avatar">
                  <div class="avatar-glow avatar-glow-1"></div>
                  <div class="avatar-glow avatar-glow-2"></div>
                  {% if course.instructor and course.instructor.avatar %}
                    <img src="{{ course.instructor.avatar }}" alt="Instructor" />
                  {% else %}
                    <img src="{{ theme_uri }}/assets/img/card_image.png" alt="Instructor" />
                  {% endif %}
                </div>
              </div>
              <div class="course-badge">
                <p>كورس</p>
              </div>
            </div>

            <div class="course-title">
              <a href="{{ course.link }}" class="stretched-link"><p>{{ course.title }}</p></a>
            </div>

            <div class="review-students">
              <div class="review">
                <svg class="star-icon" fill="none" viewBox="0 0 24 24">
                  <path d="M12 2l2.9 6.26L21.9 9.27l-5 3.86L18 21l-6-3.16L6 21l1.1-7.87-5-3.86 6.99-0.99L12 2z" fill="#FFBB54" />
                </svg>
                <p>{{ course.rating_avg }} ({{ course.rating_count }} تقييم)</p>
              </div>
              <div class="students">
                <div class="students-avatars">
                  <img class="student-avatar student-avatar-1" src="{{ theme_uri }}/assets/img/ellipse1.png" alt="" />
                  <img class="student-avatar student-avatar-2" src="{{ theme_uri }}/assets/img/ellipse2.png" alt="" />
                  <img class="student-avatar student-avatar-3" src="{{ theme_uri }}/assets/img/ellipse3.png" alt="" />
                  <div class="student-count">
                    <div class="student-count-circle">
                      <svg fill="none" viewBox="0 0 36.3884 36.9753">
                        <circle cx="18" cy="18" r="16" fill="#FFCE31" stroke="white" stroke-width="2" />
                      </svg>
                    </div>
                    <p class="student-count-text">{{ course.students_count }}+</p>
                  </div>
                </div>
                <p>الطلاب المشتركين</p>
              </div>
            </div>

            <div class="course-info">
              <div class="info-item">
                <svg class="info-icon" fill="none" viewBox="0 0 24 24">
                  <path d="M3 7h18" stroke="#999EB2" stroke-width="1.5" />
                  <path d="M4 19.5A2.5 2.5 0 016.5 17H20" stroke="#999EB2" stroke-width="1.5" />
                </svg>
                <p>{{ course.lesson_count }} محتوى</p>
              </div>
              <div class="info-divider">
                <svg fill="none" viewBox="0 0 32 1"><line stroke="white" stroke-opacity="0.05" x2="32" y1="0.5" y2="0.5" /></svg>
              </div>
              <div class="info-item level">
                <svg class="info-icon" fill="none" viewBox="0 0 24 24">
                  <path d="M4 13l4-4 4 4 8-8" stroke="#999EB2" stroke-width="1.5" />
                </svg>
                <p>{{ course.level }}</p>
              </div>
              <div class="info-divider">
                <svg fill="none" viewBox="0 0 33 1"><line stroke="white" stroke-opacity="0.05" x2="33" y1="0.5" y2="0.5" /></svg>
              </div>
              <div class="info-item">
                <svg class="info-icon" fill="none" viewBox="0 0 24 24">
                  <circle cx="12" cy="12" r="10" stroke="#999EB2" stroke-width="1.5" />
                  <path d="M12 8V12L14.5 14.5" stroke="#999EB2" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                <p>{{ course.duration|default('40 ساعة') }}</p>
              </div>
            </div>

            <div class="price-section">
              {% if course.is_free %}
                <div class="price-display">
                  <p class="new-price">مجاني</p>
                </div>
              {% elseif course.regular_price or course.sale_price %}
                {% if course.discount_percent > 0 %}
                  <div class="discount-badge">
                    <p>خصم {{ course.discount_percent }}%</p>
                  </div>
                {% endif %}
                <div class="price-display">
                  {% if course.regular_price and course.sale_price %}
                    <p class="new-price">{{ course.sale_price|number_format(2, '.', ',') }} جنيه مصري</p>
                    <p class="old-price">{{ course.regular_price|number_format(2, '.', ',') }} جنيه مصري</p>
                  {% else %}
                    <p class="new-price">{{ course.price|number_format(2, '.', ',') }} جنيه مصري</p>
                  {% endif %}
                </div>
              {% else %}
                <div class="price-display">
                  <p class="new-price">مجاني</p>
                </div>
              {% endif %}
            </div>

            <div class="action-buttons">
              {% if course.is_enrolled %}
                <a href="{{ course.first_lesson_url }}" class="learnsimply-buy-now-button buy-button">
                  <span>ابدأ التعلم</span>
                </a>
              {% elseif course.is_free %}
                <a href="{{ course.link }}" class="learnsimply-buy-now-button buy-button">
                  <span>ابدأ التعلم</span>
                </a>
              {% else %}
                {% if course.product_id %}
                <a href="{{ cart_url|default(site.url ~ '/cart-1/') }}?add-to-cart={{ course.product_id }}" class="cart-button" aria-label="أضف إلى السلة">
                  <img class="cart-icon" src="{{ theme_uri }}/assets/img/Cart.png" alt="سلة التسوق" />
                </a>
                <a href="{{ cart_url|default(site.url ~ '/cart-1/') }}?add-to-cart={{ course.product_id }}" class="learnsimply-buy-now-button buy-button">
                  <span>اضف الي السلة</span>
                </a>
                {% endif %}
              {% endif %}
            </div>
          </article>
          {% endfor %}
        </div>

        <a href="{{ courses_archive_url|default(site.url ~ '/courses/') }}" class="learnsimply-view-all-button">عرض كل الدورات</a>
      </div>
    </section>
    <!-- ===== END: Featured Courses Section ===== -->