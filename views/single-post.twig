<!doctype html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ post_title }} - {{ site.name }}</title>
  {{ fn('wp_head') }}
  <link rel="stylesheet" href="{{ theme_uri }}/assets/single-post/style.css" />
</head>
<body class="learnsimply-homepage-body single-post">

  {% include 'components/header.twig' %}

  {# ══════════════════════════════════════════════
     HERO — Featured image full-width banner
  ══════════════════════════════════════════════ #}
  <div class="sp-hero{% if not featured_image %} sp-hero--no-image{% endif %}">
    {% if featured_image %}
      <div class="sp-hero__image-wrap">
        <img class="sp-hero__image" src="{{ featured_image }}" alt="{{ post_title }}" />
        <div class="sp-hero__overlay"></div>
      </div>
    {% endif %}

    <div class="sp-hero__content sp-container">

      {# Category badge #}
      {% if category %}
        <a href="{{ category.url }}" class="sp-category-badge">{{ category.name }}</a>
      {% endif %}

      {# Title #}
      <h1 class="sp-hero__title">{{ post_title }}</h1>

      {# Meta row #}
      <div class="sp-hero__meta">
        {# Author avatar + name #}
        <div class="sp-meta-author">
          <img class="sp-meta-author__avatar"
               src="{{ author.avatar }}"
               alt="{{ author.name }}" />
          <div class="sp-meta-author__info">
            <span class="sp-meta-author__name">{{ author.name }}</span>
            <time class="sp-meta-author__date" datetime="{{ post_date_machine }}">{{ post_date }}</time>
          </div>
        </div>

        {# Divider #}
        <div class="sp-meta-divider"></div>

        {# Reading time #}
        <div class="sp-meta-stat">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
            <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.8"/>
            <path d="M12 7v5l3 3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          </svg>
          <span>{{ reading_time }} دقائق للقراءة</span>
        </div>
      </div>
    </div>
  </div>

  {# ══════════════════════════════════════════════
     BODY — Two-column: Article + Sidebar
  ══════════════════════════════════════════════ #}
  <main class="sp-main">
    <div class="sp-container sp-layout">

      {# ── Article ─────────────────────────────── #}
      <article class="sp-article" id="sp-article">

        {# Inline share strip (top) #}
        <div class="sp-share sp-share--top">
          <span class="sp-share__label">شارك المقال:</span>
          <div class="sp-share__buttons">
            <a class="sp-share__btn sp-share__btn--twitter"
               href="https://twitter.com/intent/tweet?url={{ post_url|url_encode }}&text={{ post_title|url_encode }}"
               target="_blank" rel="noopener noreferrer" aria-label="مشاركة على تويتر">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.748l7.73-8.835L1.254 2.25H8.08l4.262 5.636zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
            <a class="sp-share__btn sp-share__btn--linkedin"
               href="https://www.linkedin.com/shareArticle?mini=true&url={{ post_url|url_encode }}&title={{ post_title|url_encode }}"
               target="_blank" rel="noopener noreferrer" aria-label="مشاركة على لينكدإن">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
            <a class="sp-share__btn sp-share__btn--whatsapp"
               href="https://wa.me/?text={{ post_title|url_encode }}%20{{ post_url|url_encode }}"
               target="_blank" rel="noopener noreferrer" aria-label="مشاركة عبر واتساب">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.521.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            </a>
            <button class="sp-share__btn sp-share__btn--copy js-sp-copy-link"
                    data-url="{{ post_url }}" aria-label="نسخ الرابط">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/>
                <path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/>
              </svg>
            </button>
          </div>
        </div>

        {# Article body content #}
        <div class="sp-content entry-content">
          {{ post_content }}
        </div>

        {# Tags #}
        {% if tags|length > 0 %}
          <div class="sp-tags">
            <span class="sp-tags__label">الوسوم:</span>
            {% for tag in tags %}
              <a href="{{ tag.url }}" class="sp-tag">{{ tag.name }}</a>
            {% endfor %}
          </div>
        {% endif %}

        {# Prev / Next navigation #}
        {% if prev_post or next_post %}
        <nav class="sp-post-nav">
          {% if next_post %}
          <a href="{{ next_post.url }}" class="sp-post-nav__item sp-post-nav__item--next">
            <span class="sp-post-nav__label">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
              المقال التالي
            </span>
            <span class="sp-post-nav__title">{{ next_post.title }}</span>
          </a>
          {% endif %}
          {% if prev_post %}
          <a href="{{ prev_post.url }}" class="sp-post-nav__item sp-post-nav__item--prev">
            <span class="sp-post-nav__label">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
              المقال السابق
            </span>
            <span class="sp-post-nav__title">{{ prev_post.title }}</span>
          </a>
          {% endif %}
        </nav>
        {% endif %}

        {# Author bio card #}
        <div class="sp-author-box">
          <img class="sp-author-box__avatar"
               src="{{ author.avatar }}"
               alt="{{ author.name }}" />
          <div class="sp-author-box__body">
            <p class="sp-author-box__eyebrow">كاتب المقال</p>
            <h3 class="sp-author-box__name">{{ author.name }}</h3>
            {% if author.description %}
              <p class="sp-author-box__bio">{{ author.description }}</p>
            {% endif %}
            <a href="{{ author.url }}" class="sp-author-box__link">
              مشاهدة جميع مقالات الكاتب
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </div>

        {# Comments #}
        <div class="sp-comments">
          {{ fn('comments_template') }}
        </div>

      </article>{# end .sp-article #}

      {# ── Sidebar ─────────────────────────────── #}
      <aside class="sp-sidebar">

        {# Sticky wrapper #}
        <div class="sp-sidebar__sticky">

          {# Author card (compact) #}
          <div class="sp-sidebar-card sp-sidebar-author">
            <img class="sp-sidebar-author__avatar"
                 src="{{ author.avatar }}"
                 alt="{{ author.name }}" />
            <div>
              <p class="sp-sidebar-author__name">{{ author.name }}</p>
              <time class="sp-sidebar-author__date" datetime="{{ post_date_machine }}">{{ post_date }}</time>
            </div>
          </div>

          {# Meta stats #}
          <div class="sp-sidebar-card sp-sidebar-stats">
            {% if category %}
            <div class="sp-sidebar-stat">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 7h16M4 12h10M4 17h6"/></svg>
              <span class="sp-sidebar-stat__label">التصنيف</span>
              <a href="{{ category.url }}" class="sp-sidebar-stat__value sp-sidebar-stat__value--link">{{ category.name }}</a>
            </div>
            {% endif %}
            <div class="sp-sidebar-stat">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>
              <span class="sp-sidebar-stat__label">وقت القراءة</span>
              <span class="sp-sidebar-stat__value">{{ reading_time }} دقائق</span>
            </div>
          </div>

          {# Share card #}
          <div class="sp-sidebar-card">
            <p class="sp-sidebar-card__title">شارك المقال</p>
            <div class="sp-sidebar-share">
              <a class="sp-sidebar-share__btn"
                 href="https://twitter.com/intent/tweet?url={{ post_url|url_encode }}&text={{ post_title|url_encode }}"
                 target="_blank" rel="noopener noreferrer">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.748l7.73-8.835L1.254 2.25H8.08l4.262 5.636zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                <span>تويتر</span>
              </a>
              <a class="sp-sidebar-share__btn"
                 href="https://www.linkedin.com/shareArticle?mini=true&url={{ post_url|url_encode }}&title={{ post_title|url_encode }}"
                 target="_blank" rel="noopener noreferrer">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                <span>لينكدإن</span>
              </a>
              <a class="sp-sidebar-share__btn sp-sidebar-share__btn--wa"
                 href="https://wa.me/?text={{ post_title|url_encode }}%20{{ post_url|url_encode }}"
                 target="_blank" rel="noopener noreferrer">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.521.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                <span>واتساب</span>
              </a>
            </div>
          </div>

          {# Related posts (sidebar) #}
          {% if related_posts|length > 0 %}
          <div class="sp-sidebar-card">
            <p class="sp-sidebar-card__title">مقالات ذات صلة</p>
            <ul class="sp-related-list">
              {% for rel in related_posts %}
              <li class="sp-related-item">
                {% if rel.thumbnail %}
                  <img class="sp-related-item__thumb" src="{{ rel.thumbnail }}" alt="{{ rel.title }}" />
                {% endif %}
                <div class="sp-related-item__body">
                  <a href="{{ rel.url }}" class="sp-related-item__title">{{ rel.title }}</a>
                  <span class="sp-related-item__date">{{ rel.date }}</span>
                </div>
              </li>
              {% endfor %}
            </ul>
          </div>
          {% endif %}

        </div>{# end .sp-sidebar__sticky #}

      </aside>{# end .sp-sidebar #}

    </div>{# end .sp-layout #}
  </main>

  {# ══════════════════════════════════════════════
     RELATED POSTS — full-width grid at the bottom
  ══════════════════════════════════════════════ #}
  {% if related_posts|length > 0 %}
  <section class="sp-more-section">
    <div class="sp-container">
      <div class="sp-more-header">
        <h2 class="sp-more-title">مقالات قد تهمك</h2>
        <a href="{{ site_url }}/blog/" class="sp-more-all">عرض جميع المقالات ←</a>
      </div>
      <div class="sp-more-grid">
        {% for rel in related_posts %}
        <a href="{{ rel.url }}" class="sp-more-card">
          {% if rel.thumbnail %}
          <div class="sp-more-card__img-wrap">
            <img src="{{ rel.thumbnail }}" alt="{{ rel.title }}" class="sp-more-card__img" />
          </div>
          {% endif %}
          <div class="sp-more-card__body">
            <time class="sp-more-card__date">{{ rel.date }}</time>
            <h3 class="sp-more-card__title">{{ rel.title }}</h3>
          </div>
        </a>
        {% endfor %}
      </div>
    </div>
  </section>
  {% endif %}

  {% include 'components/footer.twig' %}
  {% include 'components/whatsapp-button.twig' %}

  {{ fn('wp_footer') }}

  <script>
  // Copy-link button
  (function () {
    document.querySelectorAll('.js-sp-copy-link').forEach(function (btn) {
      btn.addEventListener('click', function () {
        navigator.clipboard.writeText(btn.dataset.url).then(function () {
          btn.classList.add('copied');
          setTimeout(function () { btn.classList.remove('copied'); }, 2000);
        });
      });
    });
  })();
  </script>

</body>
</html>
